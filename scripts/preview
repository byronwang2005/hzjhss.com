#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-4173}"
OPEN_BROWSER="${OPEN_BROWSER:-1}"

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required to run the preview server." >&2
  exit 1
fi

pick_port() {
  local port="$1"

  while python3 - "$HOST" "$port" <<'PY' >/dev/null 2>&1
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])

with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
    sock.bind((host, port))
PY
  do
    printf '%s' "$port"
    return 0
  done

  while :; do
    port=$((port + 1))
    if python3 - "$HOST" "$port" <<'PY' >/dev/null 2>&1
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])

with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
    sock.bind((host, port))
PY
    then
      printf '%s' "$port"
      return 0
    fi
  done
}

PORT="$(pick_port "$PORT")"
URL="http://${HOST}:${PORT}/"

echo "Previewing ${ROOT_DIR}"
echo "Serving ${URL}"
echo "Press Ctrl+C to stop."

if [[ "$OPEN_BROWSER" == "1" ]] && command -v open >/dev/null 2>&1; then
  open "$URL" >/dev/null 2>&1 || true
fi

cd "$ROOT_DIR"
exec python3 -m http.server "$PORT" --bind "$HOST"
